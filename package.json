{
	"name": "directus-extension-gravatar",
	"description": "Directus app extension that renders Gravatar avatars from email fields in collection views.",
	"version": "1.0.2",
	"type": "module",
	"license": "MIT",
	"author": "wigandt.tech",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wigandt-tech/directus-extension-gravatar.git"
	},
	"homepage": "https://github.com/wigandt-tech/directus-extension-gravatar#readme",
	"bugs": {
		"url": "https://github.com/wigandt-tech/directus-extension-gravatar/issues"
	},
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-display",
		"display",
		"avatar",
		"gravatar",
		"email"
	],
	"directus:extension": {
		"host": "^11.0.0 || ^12.0.0",
		"type": "display",
		"path": "dist/index.js",
		"source": "src/display/index.ts"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "directus-extension build",
		"typecheck": "vue-tsc --noEmit",
		"test": "vitest run",
		"check": "npm run typecheck && npm run test && npm run build && npm pack --dry-run --ignore-scripts",
		"prepare": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"add": "directus-extension add"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "^17.1.4",
		"@vitejs/plugin-vue": "^6.0.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vitest": "^4.0.16",
		"vue": "3.5.35",
		"vue-i18n": "^11.4.4",
		"vue-tsc": "^3.3.2"
	},
	"overrides": {
		"vue": "$vue"
	}
}
